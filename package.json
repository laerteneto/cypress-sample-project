{
  "name": "admintestscypresspoc",
  "version": "0.0.1",
  "description": "Cypress POC for the new admin portal",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf ./node_modules/",
    " --- CYPRESS DEV SCRIPTS ---- ": "",
    "cy:open": "cypress open",
    "cy:run": "cypress run --browser chrome",
    "cy:run:headless": "cypress run --browser chrome --headless --spec 'cypress/integration/**/*.spec.js'",
    "cy:run:debug": "cypress run --browser chrome --headless --spec \"**/functional/**/*.feature\" -e TAGS='@DEBUG'",
    
    " --- CYPRESS PIPELINE SCRIPTS WITHOUT FILE RESULTS ---- ": "",
    "cy:run:chrome": "cypress run --browser chrome --headless --spec \"**/functional/**/*.feature\" -e TAGS='not @ignore-integration and not @deprecated and not @ignore'",
    "cy:run:firefox": "cypress run --browser firefox --headless",
    "cy:run:edge": "cypress run --browser edge --headless",
    "cy:run:api": "cypress run --browser chrome --headless --spec \"**/api/**/*.spec.js\"",

    " --- CYPRESS PIPELINE SCRIPTS WITH FILE RESULTS ---- ": "",
    "test:ui:headless:mocha": "yarn cy:clean:results; yarn cy:run:headless; yarn cy:results",

    " --- MOCHAWESOME REPORT SCRIPTS ---- ": "",
    "cy:results": "yarn cy:merge:results; yarn cy:final:results",
    "cy:clean:results": "rm -rf cypress/results/*",
    "cy:merge:results": "mochawesome-merge cypress/results/*.json > cypress/results/output.json",
    "cy:final:results": "marge cypress/results/output.json --reportDir cypress/results/"
  },
  "keywords": [
    "tests",
    "js",
    "cypress"
  ],
  "author": "Laerte Mello",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^6.4.0",
    "cypress-xpath": "^1.6.1",
    "cypress-waitfor": "^1.1.0",
    "mocha": "^8.2.1",
    "mochawesome": "^6.2.1",
    "mochawesome-merge": "^4.2.0"
  }
}
